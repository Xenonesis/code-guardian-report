{
  "name": "code-guardian-report",
  "private": true,
  "version": "15.0.0",
  "description": "Code analysis tool with security scanning and metrics reporting",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:prod": "npm run clean && npm run lint && npm run type-check && next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "preview": "node .next/standalone/server.js",
    "start:prod": "NODE_ENV=production next start -p ${PORT:-3000}",
    "lighthouse:home:desktop": "npx lighthouse http://localhost:3000 --preset=desktop --output=json --output-path=.lighthouse-home-desktop.json --chrome-flags=\"--headless=new --no-sandbox --disable-dev-shm-usage\"",
    "lighthouse:legal:desktop": "npx lighthouse http://localhost:3000/legal --preset=desktop --output=json --output-path=.lighthouse-legal-desktop.json --chrome-flags=\"--headless=new --no-sandbox --disable-dev-shm-usage\"",
    "lighthouse:home:mobile": "npx lighthouse http://localhost:3000 --output=json --output-path=.lighthouse-home-mobile.json --chrome-flags=\"--headless=new --no-sandbox --disable-dev-shm-usage\"",
    "lighthouse:legal:mobile": "npx lighthouse http://localhost:3000/legal --output=json --output-path=.lighthouse-legal-mobile.json --chrome-flags=\"--headless=new --no-sandbox --disable-dev-shm-usage\"",
    "lighthouse:all": "npm run lighthouse:home:desktop && npm run lighthouse:legal:desktop && npm run lighthouse:home:mobile && npm run lighthouse:legal:mobile",
    "lhci": "npx lhci autorun",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "lint:strict": "eslint . --quiet",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "clean": "rimraf .next node_modules/.cache dist out",
    "clean:all": "rimraf .next node_modules/.cache dist out .turbo",
    "postbuild": "echo 'Build completed successfully!'",
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL) try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch (e) {}\"",
    "update-contributors": "node scripts/update-contributors.js",
    "setup-git-hooks": "node scripts/setup-git-hooks.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "ci:validate": "npm run lint:strict && npm run type-check && npm run test",
    "ci:build": "npm run ci:validate && npm run build",
    "docker:build": "docker build -t code-guardian:latest .",
    "docker:run": "docker run -p 3000:3000 code-guardian:latest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "health-check": "curl -f http://localhost:3000/api/health || exit 1",
    "deploy:vercel": "vercel --prod",
    "deploy:preview": "vercel",
    "mcp:build": "tsc -p tsconfig.mcp.json && tsc-alias -p tsconfig.mcp.json",
    "mcp:stdio": "node dist/mcp/mcp/transports/stdio.js",
    "mcp:http": "node dist/mcp/mcp/transports/http.js",
    "mcp:dev": "npx tsx src/mcp/transports/stdio.ts",
    "mcp:dev:http": "npx tsx src/mcp/transports/http.ts",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node dist/mcp/mcp/transports/stdio.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,sh,html,xml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@lezer/cpp": "^1.1.5",
    "@lezer/java": "^1.1.3",
    "@lezer/python": "^1.1.18",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/babel__traverse": "^7.28.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esprima": "^4.0.1",
    "esquery": "^1.7.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lenis": "^1.3.20",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "next-auth": "^4.24.14",
    "next-nprogress-bar": "^2.4.7",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "prisma": "^7.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "web-push": "^3.6.7",
    "web-tree-sitter": "^0.26.7",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/markdown": "^7.5.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "strip-comments": "^2.0.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.4",
    "@tootallnate/once": ">=3.0.1"
  }
}
