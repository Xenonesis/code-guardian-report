# Code Guardian Enterprise - Environment Configuration
# Copy this file to .env.local and configure your values
# For Next.js, client-side variables must use NEXT_PUBLIC_ prefix
#
# ⚠️  IMPORTANT: ALL VARIABLES IN THIS FILE ARE OPTIONAL FOR LOCAL DEVELOPMENT
# The application works perfectly without any configuration using intelligent defaults.
#
# Only configure the variables you need for specific features:
# - GitHub Integration: Requires GitHub OAuth credentials
# - AI Features: Requires at least one AI provider API key
# - Analytics: Requires analytics service credentials
#
# For a quick start, simply run: npm install && npm run dev
# No environment variables needed!

# =============================================================================
# APPLICATION CONFIGURATION (Optional - uses sensible defaults)
# =============================================================================
NEXT_PUBLIC_APP_NAME="Code Guardian Enterprise"
NEXT_PUBLIC_APP_VERSION="11.0.0"
NEXT_PUBLIC_APP_DESCRIPTION="Enterprise-grade static code analysis platform powered by artificial intelligence"
NEXT_PUBLIC_APP_URL="https://code-guardian-report.vercel.app"
NODE_ENV="production"

# =============================================================================
# NEON DATABASE CONFIGURATION (Primary - replaces Firebase)
# =============================================================================
# ℹ️  Prisma Postgres is the primary database.
DATABASE_URL="postgres://11734fb516663e8b5ebd7275183ab0aa823ee81591d557f1d4418b3145284e22:sk_KU2hhSPUHe7ne2ccIUBy1@db.prisma.io:5432/postgres?sslmode=require"

# =============================================================================
# NEXTAUTH CONFIGURATION (Primary Authentication)
# =============================================================================
# ℹ️  NextAuth handles GitHub OAuth authentication
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"

# =============================================================================
# PWA CONFIGURATION (Optional - for push notifications)
# =============================================================================
# ℹ️  Push notifications are OPTIONAL and currently disabled
# To enable in the future, configure VAPID keys with: npx web-push generate-vapid-keys

# Push notifications VAPID key (client-side)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key"

# Push notifications VAPID key (server-side - keep secret!)
# VAPID_PRIVATE_KEY="your_vapid_private_key"
# VAPID_SUBJECT="mailto:admin@yourdomain.com"

# =============================================================================
# AI PROVIDER CONFIGURATION (Optional - for AI-powered features)
# =============================================================================
# ℹ️  AI features are OPTIONAL. Configure at least one provider to enable:
# - AI-generated fix suggestions
# - Natural language vulnerability explanations
# - Intelligent code analysis
# - Chatbot assistance
#
# Choose one or more providers:

# OpenAI Configuration (GPT-4, GPT-3.5-turbo)
# Get your API key: https://platform.openai.com/api-keys
OPENAI_API_URL="https://api.openai.com/v1"
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_MAX_TOKENS="4096"

# Anthropic Claude Configuration (Claude 3 Opus, Sonnet, Haiku)
# Get your API key: https://console.anthropic.com/
ANTHROPIC_API_URL="https://api.anthropic.com/v1"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
ANTHROPIC_MODEL="claude-3-sonnet-20240229"
ANTHROPIC_MAX_TOKENS="4096"

# Google Gemini Configuration (Gemini Pro)
# Get your API key: https://makersuite.google.com/app/apikey
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-pro"

# =============================================================================
# GITHUB INTEGRATION (Optional - for direct repository analysis)
# =============================================================================
# ℹ️  GitHub integration is OPTIONAL. Only needed if you want to:
# - Analyze GitHub repositories directly without cloning
# - Access private repositories
# - View commit history and branch analysis
#
# To set up GitHub OAuth:
# 1. Go to GitHub Settings > Developer settings > OAuth Apps
# 2. Click "New OAuth App"
# 3. Set Homepage URL: http://localhost:3000 (for development)
# 4. Set Callback URL: http://localhost:3000/api/auth/github/callback
# 5. Copy Client ID and Client Secret below

GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
NEXT_PUBLIC_GITHUB_REDIRECT_URI="https://code-guardian-report.vercel.app/auth/github"

# =============================================================================
# THIRD-PARTY INTEGRATIONS (Optional - Server-side)
# =============================================================================
# ℹ️  All integrations below are OPTIONAL

# Slack Integration (for security alerts)
SLACK_WEBHOOK_URL="your_slack_webhook_url"
SLACK_CHANNEL="#security-alerts"

# Email Notifications
EMAIL_SERVICE_ENABLED="false"
EMAIL_FROM="noreply@codeguardian.ai"
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Core Features (client-side)
NEXT_PUBLIC_FEATURE_AI_ANALYSIS="true"
NEXT_PUBLIC_FEATURE_BULK_UPLOAD="true"
NEXT_PUBLIC_FEATURE_EXPORT_REPORTS="true"
NEXT_PUBLIC_FEATURE_DARK_MODE="true"

# Advanced Features
NEXT_PUBLIC_FEATURE_REAL_TIME_ANALYSIS="true"
NEXT_PUBLIC_FEATURE_COLLABORATION="false"
NEXT_PUBLIC_FEATURE_API_ACCESS="false"
NEXT_PUBLIC_FEATURE_ENTERPRISE_SSO="false"

# Experimental Features
NEXT_PUBLIC_FEATURE_VOICE_COMMANDS="false"
NEXT_PUBLIC_FEATURE_MOBILE_APP="true"
NEXT_PUBLIC_FEATURE_OFFLINE_MODE="true"

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Vercel Analytics (automatically enabled)
NEXT_PUBLIC_ANALYTICS_ENABLED="true"
NEXT_PUBLIC_ANALYTICS_ANONYMIZE_IP="true"
NEXT_PUBLIC_ANALYTICS_RESPECT_DNT="true"

# =============================================================================
# COMPLIANCE & LEGAL
# =============================================================================

# Privacy Compliance
NEXT_PUBLIC_GDPR_COMPLIANCE="true"
NEXT_PUBLIC_CCPA_COMPLIANCE="true"
NEXT_PUBLIC_COOKIE_CONSENT="true"

# Terms & Conditions
NEXT_PUBLIC_TERMS_VERSION="1.0"
NEXT_PUBLIC_PRIVACY_VERSION="1.0"
NEXT_PUBLIC_LAST_UPDATED="2026-01-01"

# =============================================================================
# LOCALIZATION
# =============================================================================

# Internationalization
NEXT_PUBLIC_I18N_ENABLED="false"
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"
NEXT_PUBLIC_SUPPORTED_LOCALES="en-US,es-ES,fr-FR,de-DE,ja-JP,zh-CN"
