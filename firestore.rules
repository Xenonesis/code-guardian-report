rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function incomingOwner() {
      return isOwner(request.resource.data.userId);
    }

    function existingOwner() {
      return isOwner(resource.data.userId);
    }

    function keepsOwner() {
      return request.resource.data.userId == resource.data.userId;
    }

    function webhookPath(webhookId) {
      return /databases/$(database)/documents/webhooks/$(webhookId);
    }

    function ownsWebhook(webhookId) {
      return signedIn()
        && webhookId is string
        && exists(webhookPath(webhookId))
        && get(webhookPath(webhookId)).data.userId == request.auth.uid;
    }

    function resourceWebhookOwner() {
      return resource.data.webhookId is string && ownsWebhook(resource.data.webhookId);
    }

    function incomingWebhookOwner() {
      return request.resource.data.webhookId is string
        && ownsWebhook(request.resource.data.webhookId);
    }

    function sharedWithRequester() {
      return signedIn()
        && resource.data.sharedWith is list
        && request.auth.uid in resource.data.sharedWith;
    }

    // users: Personally identifiable account profile. Owner-only access.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // analysisResults: User-generated analysis history; readable by authenticated users,
    // and owner-bound for writes to prevent cross-user data injection.
    match /analysisResults/{analysisId} {
      allow read: if existingOwner() || resource.data.isPublic == true;
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }
    
    // userStats: Aggregated usage metrics tied to a specific user identity.
    match /userStats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // userSettings: Preferences and non-sensitive configuration tied to user account.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // analysisHistory: Legacy collection retained for backward compatibility.
    match /analysisHistory/{document} {
      allow read: if existingOwner();
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }

    // tasks: Dashboard task manager data. Owner-only access.
    match /tasks/{taskId} {
      allow read: if existingOwner();
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }
    
    // pushSubscriptions: Endpoint + keys required for push delivery, owner-only access.
    match /pushSubscriptions/{subscriptionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // analytics: Event telemetry. Owner-only read and constrained create schema.
    match /analytics/{analyticsId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasAll(['userId', 'event', 'timestamp']);
    }
    
    // publicResources: Shared static resources. Read-only at client edge; writes through admin path.
    match /publicResources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin-only via Firebase Admin SDK
    }
    
    // github_repositories: Public metadata catalog by design for collaboration/discovery.
    // No secrets or user-private attributes should be stored in this collection.
    match /github_repositories/{repoId} {
      allow read: if true;
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }
    
    // github_analyses: Public analysis snapshots by design for shareable reporting.
    // Any user-identifying fields should be excluded before persistence.
    match /github_analyses/{analysisId} {
      allow read: if true;
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }

    // customRules: Users manage their own rules; public/shared rules are readable.
    match /customRules/{ruleId} {
      allow read: if existingOwner()
        || resource.data.isPublic == true
        || sharedWithRequester();
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }

    // webhooks: Repository monitoring configs include signing secrets, so they
    // must remain owner-only. Cloud Functions process inbound webhook events.
    match /webhooks/{webhookId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // monitoringRules: Owner-managed automation rules for a webhook.
    match /monitoringRules/{ruleId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // webhookLogs/action logs/scan queues/results are written by Cloud Functions.
    match /webhookLogs/{logId} {
      allow read: if existingOwner() || resourceWebhookOwner();
      allow create: if incomingOwner() || incomingWebhookOwner();
      allow update, delete: if false;
    }

    match /webhookActionLogs/{logId} {
      allow read: if existingOwner() || resourceWebhookOwner();
      allow write: if false;
    }

    match /scanQueue/{scanId} {
      allow read: if existingOwner() || resourceWebhookOwner();
      allow write: if false;
    }

    match /scanResults/{scanId} {
      allow read: if existingOwner() || resourceWebhookOwner();
      allow write: if false;
    }

    match /webhookTasks/{taskId} {
      allow read: if existingOwner() || resourceWebhookOwner();
      allow write: if false;
    }

    match /scheduledNotifications/{notificationId} {
      allow read: if existingOwner();
      allow create: if incomingOwner();
      allow update, delete: if existingOwner() && keepsOwner();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.userIds is list
        && request.auth.uid in resource.data.userIds;
      allow update: if signedIn()
        && resource.data.userIds is list
        && request.auth.uid in resource.data.userIds
        && request.resource.data.userIds == resource.data.userIds;
      allow create, delete: if false;
    }

    // feedback is accepted through the server API so rate limits and validation
    // are enforced consistently.
    match /feedback/{feedbackId} {
      allow read, write: if false;
    }

    match /errorLogs/{logId} {
      allow read, write: if false;
    }

    match /pwaAnalytics/{eventId} {
      allow read, write: if false;
    }
    
    // Deny all other access by default (security best practice)
    match /{document=**} {
      allow read, write: if false;
    }
 }
}
