rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users: Personally identifiable account profile. Owner-only access.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // analysisResults: User-generated analysis history; readable by authenticated users,
    // but create is ownership-bound to prevent cross-user data injection.
    match /analysisResults/{analysisId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // userStats: Aggregated usage metrics tied to a specific user identity.
    match /userStats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // userSettings: Preferences and non-sensitive configuration tied to user account.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // analysisHistory: Legacy collection retained for backward compatibility.
    match /analysisHistory/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // pushSubscriptions: Endpoint + keys required for push delivery, owner-only access.
    match /pushSubscriptions/{subscriptionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // analytics: Event telemetry. Owner-only read and constrained create schema.
    match /analytics/{analyticsId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasAll(['userId', 'event', 'timestamp']);
    }
    
    // publicResources: Shared static resources. Read-only at client edge; writes through admin path.
    match /publicResources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin-only via Firebase Admin SDK
    }
    
    // github_repositories: Public metadata catalog by design for collaboration/discovery.
    // No secrets or user-private attributes should be stored in this collection.
    match /github_repositories/{repoId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // github_analyses: Public analysis snapshots by design for shareable reporting.
    // Any user-identifying fields should be excluded before persistence.
    match /github_analyses/{analysisId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // Deny all other access by default (security best practice)
    match /{document=**} {
      allow read, write: if false;
    }
 }
}
